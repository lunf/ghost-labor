{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Ho_Chi_Minh",
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "npm non-major dependencies"
    },
    {
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "docker non-major dependencies"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "prisma",
        "@prisma/client"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "core framework dependencies"
    }
  ]
}
