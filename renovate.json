{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Ho_Chi_Minh",
  "schedule": [
    "before 6am on Monday"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "npm non-major dependencies"
    },
    {
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "docker non-major dependencies"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "postUpdateOptions": [
        "npmDedupe"
      ]
    },
    {
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "prisma",
        "@prisma/client"
      ],
      "groupName": "core framework dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "separateMajorMinor": true,
      "separateMultipleMajor": true
    }
  ]
}
