{
  "name": "ghost-labor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "next build",
    "start": "prisma generate && next start",
    "lint": "next lint",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "worker": "prisma generate && tsx scripts/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma generate && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "next": "^15.5.13",
    "pg-boss": "^10.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.76",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@types/nodemailer": "^6.4.23"
  },
  "prisma": {
    "seed": "prisma generate && tsx prisma/seed.ts"
  }
}
