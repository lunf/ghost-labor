{
  "name": "ghost-labor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "next build",
    "start": "prisma generate && next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "prepare": "test -f scripts/setup-git-hooks.sh && npm run setup:hooks || exit 0",
    "setup:hooks": "sh scripts/setup-git-hooks.sh",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "worker": "prisma generate && tsx scripts/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma generate && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.8.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.2",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "prisma": {
    "seed": "prisma generate && tsx prisma/seed.ts"
  }
}
